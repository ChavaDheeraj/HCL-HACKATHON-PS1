<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="AutomationExerciseSuite" thread-count="3" parallel="tests">

    <listeners>
        <listener class-name="com.srm.listeners.TestListener"/>
        <listener class-name="com.srm.listeners.AnnotationTransformer"/>
    </listeners>

    <test name="Login Tests">
        <classes>
            <class name="com.srm.tests.LoginTest"/>
        </classes>
    </test>

    <test name="Signup Test">
        <classes>
            <class name="com.srm.tests.SignupTest"/>
        </classes>
    </test>

    <test name="Products Test">
        <classes>
            <class name="com.srm.tests.ProductsTest"/>
        </classes>
    </test>

    <test name="Cart Test">
        <classes>
            <class name="com.srm.tests.CartTest"/>
        </classes>
    </test>

    <test name="Checkout Flow Test">
        <classes>
            <class name="com.srm.tests.CheckoutFlowTest"/>
        </classes>
    </test>

    <test name="Form Validation Tests">
        <classes>
            <class name="com.srm.tests.FormValidationTest"/>
        </classes>
    </test>

    <test name="Contact Us Test">
        <classes>
            <class name="com.srm.tests.ContactUs"/>
        </classes>
    </test>

</suite>
